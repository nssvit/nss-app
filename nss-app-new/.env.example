# Database (required)
DATABASE_URL=
DIRECT_URL=

# Better Auth (required)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Redis / Upstash (optional — caching + dual DB switching)
UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Neon failover (optional — dual DB mode)
NEON_DATABASE_URL=
NEON_DIRECT_URL=

# Email via Resend (optional — password reset + email verification)
# Without this, emails are logged to console (dev mode)
# Get a free key at https://resend.com (3k emails/month free)
RESEND_API_KEY=
EMAIL_FROM=NSS App <onboarding@resend.dev>
